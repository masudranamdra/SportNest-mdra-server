# ========================================================
# SERVER ENVIRONMENT VARIABLES (BACKEND / VERCEL API)
# ========================================================
# These variables should be added to the Vercel Dashboard
# under Settings -> Environment Variables for your Server project.

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Secure Secret Keys (Must be at least 32 characters long)
# You can use the same 64-character hex string for both
JWT_SECRET=your_super_secure_32_plus_character_string_here
BETTER_AUTH_SECRET=your_super_secure_32_plus_character_string_here

# The URL of your deployed Frontend Client (for CORS)
# Replace this with your frontend's actual Vercel URL once deployed
CLIENT_URL=https://your-frontend-project.vercel.app
